# ============================================================
# Modern Space Styling — Environment Variables
# Copy this file to .env.local (never commit .env.local)
# Add all vars to Vercel Dashboard → Project → Settings → Environment Variables
# ============================================================

# --------------------------------------------------
# SUPABASE
# --------------------------------------------------
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key
# Service role key is used SERVER-SIDE ONLY to bypass RLS for admin actions

# --------------------------------------------------
# TWILIO SMS
# --------------------------------------------------
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your-twilio-auth-token
TWILIO_PHONE_NUMBER=+61XXXXXXXXXX
# Twilio webhook URL to set in Twilio Console:
#   https://www.modernspacestyling.com.au/api/twilio-incoming

# --------------------------------------------------
# ENCRYPTION
# --------------------------------------------------
LOCKBOX_ENCRYPTION_KEY=your-32-character-secret-key-here!!
# Must be exactly 32 characters for AES-256
# Generate: node -e "console.log(require('crypto').randomBytes(16).toString('hex'))"

# --------------------------------------------------
# ADMIN
# --------------------------------------------------
ADMIN_SECRET_TOKEN=your-long-random-admin-api-token
# Used to protect admin-only API endpoints
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"

# --------------------------------------------------
# OPTIONAL — FUTURE USE
# --------------------------------------------------
OPENAI_API_KEY=sk-...
GOOGLE_MAPS_API_KEY=AIza...
RECAPTCHA_SECRET_KEY=6L...
